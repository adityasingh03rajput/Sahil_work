{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "generate-icons": "node scripts/generate-icons.cjs",
    "generate-android-icons": "node scripts/generate-android-icons.cjs",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "cross-env ELECTRON=true vite build && electron-builder",
    "electron:build:win": "cross-env ELECTRON=true vite build && electron-builder --win",
    "electron:build:portable": "cross-env ELECTRON=true vite build && electron-builder --win portable",
    "build:exe:app": "cross-env ELECTRON=true vite build && electron-builder --config electron-builder-app.json --win",
    "build:exe:admin": "cross-env ELECTRON=true vite build && electron-builder --config electron-builder-admin.json --win",
    "build:exe:both": "cross-env ELECTRON=true vite build && electron-builder --config electron-builder-app.json --win && electron-builder --config electron-builder-admin.json --win"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
